{
  "tab": "Tickets",
  "description": "All QA tickets created for Medium, High, and Critical severity conversations. Retention: Indefinite.",
  "columns": [
    { "col": "A",  "name": "ticket_id",          "type": "string",   "note": "UUID generated by WF4" },
    { "col": "B",  "name": "date",               "type": "date",     "note": "Date ticket was created (YYYY-MM-DD)" },
    { "col": "C",  "name": "conversation_id",    "type": "string",   "note": "Intercom conversation ID" },
    { "col": "D",  "name": "player_id",          "type": "string",   "note": "Player identifier" },
    { "col": "E",  "name": "agent_name",         "type": "string",   "note": "Agent who handled the conversation" },
    { "col": "F",  "name": "severity",           "type": "string",   "note": "Medium | High | Critical" },
    { "col": "G",  "name": "issue_category",     "type": "string",   "note": "Issue category from AI analysis" },
    { "col": "H",  "name": "summary",            "type": "string",   "note": "AI-generated summary" },
    { "col": "I",  "name": "key_quotes",         "type": "string",   "note": "Player key quotes (JSON array)" },
    { "col": "J",  "name": "recommended_action", "type": "string",   "note": "Specific action recommended by AI" },
    { "col": "K",  "name": "assigned_to",        "type": "string",   "note": "Team leader name or 'QA-Inbox' fallback" },
    { "col": "L",  "name": "status",             "type": "string",   "note": "Open | In Review | Closed" },
    { "col": "M",  "name": "feedback",           "type": "string",   "note": "Team leader feedback: Agree | Disagree (blank until reviewed)" },
    { "col": "N",  "name": "feedback_processed", "type": "boolean",  "note": "TRUE once WF7 has processed this feedback row" },
    { "col": "O",  "name": "intercom_link",      "type": "string",   "note": "Direct URL to conversation in Intercom" },
    { "col": "P",  "name": "created_at",         "type": "datetime", "note": "Ticket creation timestamp (ISO 8601)" }
  ],
  "dedup_key": "ticket_id",
  "retention_days": null,
  "notes": "Team leaders fill in column M (Agree/Disagree) directly in this sheet. WF7 polls every 6 hours."
}
