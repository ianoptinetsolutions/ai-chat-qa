{
  "name": "WF4 - Auto Ticket Creation",
  "nodes": [
    {
      "parameters": {},
      "id": "c9d0e1f2-a3b4-4c5d-6e7f-8a9b0c1d2e3f",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst { randomUUID } = require('crypto');\nconst ticketId = randomUUID();\nconst now = new Date();\nconst severity = data.severity || 'Medium';\nconst issueCategory = data.issue_category || 'Other';\nconst playerId = data.player_id || 'unknown';\nconst agentName = data.agent_name || 'Unknown';\nconst ticketTitle = `[${severity.toUpperCase()}] ${issueCategory} \u2014 Player ${playerId}`;\nconst slackDmText = `*New QA Ticket: ${ticketTitle}*\\n\\n:id: *Ticket:* ${ticketId}\\n:bust_in_silhouette: *Agent:* ${agentName}\\n:warning: *Severity:* ${severity}\\n\\n*Summary:*\\n${data.summary || ''}\\n\\n*Recommended Action:*\\n${data.recommended_action || ''}\\n\\n*Conversation:* <${data.intercom_link || ''}|View in Intercom>\\n\\n_Please review and mark Agree/Disagree in the Tickets table._`;\nreturn [{ json: { ticket_id: ticketId, date: now.toISOString().split('T')[0], conversation_id: data.conversation_id || '', player_id: playerId, agent_name: agentName, severity, issue_category: issueCategory, summary: data.summary || '', key_quotes: data.key_quotes || '[]', recommended_action: data.recommended_action || '', assigned_to: '', status: 'Open', feedback: '', feedback_processed: false, intercom_link: data.intercom_link || '', created_at: now.toISOString(), _ticket_title: ticketTitle, _slack_dm_text: slackDmText, _severity: severity } }];"
      },
      "id": "d0e1f2a3-b4c5-4d6e-7f8a-9b0c1d2e3f4a",
      "name": "Build Ticket",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/agent_team_mapping?agent_name=eq.{{ encodeURIComponent($json.agent_name) }}&select=agent_name,team_leader_name,team_leader_slack_id&limit=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "apikey", "value": "={{ $env.SUPABASE_API_KEY }}"},
            {"name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_API_KEY }}"}
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b",
      "name": "Lookup Team Leader",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [540, 300]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst body = response.body || [];\nconst ticketData = $('Build Ticket').item.json;\nconst mapping = Array.isArray(body) && body.length > 0 ? body[0] : null;\nreturn [{ json: { ...ticketData, team_leader_name: mapping ? mapping.team_leader_name || '' : '', team_leader_slack_id: mapping ? mapping.team_leader_slack_id || '' : '' } }];"
      },
      "id": "wf4-extract-team-leader-001",
      "name": "Extract Team Leader",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
          "conditions": [
            {
              "id": "f2a3b4c5-d6e7-4f8a-9b0c-1d2e3f4a5b6c",
              "leftValue": "={{ $json.team_leader_slack_id }}",
              "rightValue": "",
              "operator": {"type": "string", "operation": "notEmpty"}
            }
          ],
          "combinator": "and"
        }
      },
      "id": "a3b4c5d6-e7f8-4a9b-0c1d-2e3f4a5b6c7d",
      "name": "Check Mapping Found",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [980, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "b4c5d6e7-f8a9-4b0c-1d2e-3f4a5b6c7d8e",
              "name": "assigned_to",
              "value": "={{ $json.team_leader_name }}",
              "type": "string"
            },
            {
              "id": "c5d6e7f8-a9b0-4c1d-2e3f-4a5b6c7d8e9f",
              "name": "slack_id",
              "value": "={{ $json.team_leader_slack_id }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "d6e7f8a9-b0c1-4d2e-3f4a-5b6c7d8e9f0a",
      "name": "Set Assigned To (Leader)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [1200, 200]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "e7f8a9b0-c1d2-4e3f-4a5b-6c7d8e9f0a1b",
              "name": "assigned_to",
              "value": "QA-Inbox",
              "type": "string"
            },
            {
              "id": "f8a9b0c1-d2e3-4f4a-5b6c-7d8e9f0a1b2c",
              "name": "slack_id",
              "value": "#chat-qa-inbox",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a9b0c1d2-e3f4-4a5b-6c7d-8e9f0a1b2c3d",
      "name": "Set Assigned To (Fallback)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [1200, 400]
    },
    {
      "parameters": {
        "operation": "create",
        "tableId": "tickets",
        "fieldsUi": {
          "fieldValues": [
            {"fieldId": "ticket_id", "fieldValue": "={{ $('Build Ticket').item.json.ticket_id }}"},
            {"fieldId": "date", "fieldValue": "={{ $('Build Ticket').item.json.date }}"},
            {"fieldId": "conversation_id", "fieldValue": "={{ $('Build Ticket').item.json.conversation_id }}"},
            {"fieldId": "player_id", "fieldValue": "={{ $('Build Ticket').item.json.player_id }}"},
            {"fieldId": "agent_name", "fieldValue": "={{ $('Build Ticket').item.json.agent_name }}"},
            {"fieldId": "severity", "fieldValue": "={{ $('Build Ticket').item.json.severity }}"},
            {"fieldId": "issue_category", "fieldValue": "={{ $('Build Ticket').item.json.issue_category }}"},
            {"fieldId": "summary", "fieldValue": "={{ $('Build Ticket').item.json.summary }}"},
            {"fieldId": "key_quotes", "fieldValue": "={{ $('Build Ticket').item.json.key_quotes }}"},
            {"fieldId": "recommended_action", "fieldValue": "={{ $('Build Ticket').item.json.recommended_action }}"},
            {"fieldId": "assigned_to", "fieldValue": "={{ $json.assigned_to }}"},
            {"fieldId": "status", "fieldValue": "={{ $('Build Ticket').item.json.status }}"},
            {"fieldId": "feedback", "fieldValue": "={{ $('Build Ticket').item.json.feedback }}"},
            {"fieldId": "feedback_processed", "fieldValue": "={{ $('Build Ticket').item.json.feedback_processed }}"},
            {"fieldId": "intercom_link", "fieldValue": "={{ $('Build Ticket').item.json.intercom_link }}"},
            {"fieldId": "created_at", "fieldValue": "={{ $('Build Ticket').item.json.created_at }}"}
          ]
        }
      },
      "credentials": {"supabaseApi": {"id": "supabase_api", "name": "Supabase"}},
      "id": "b0c1d2e3-f4a5-4b6c-7d8e-9f0a1b2c3d4e",
      "name": "Insert Ticket to Supabase",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1420, 300]
    },
    {
      "parameters": {
        "operation": "post",
        "channel": "={{ $json.slack_id }}",
        "text": "={{ $('Build Ticket').item.json._slack_dm_text }}",
        "otherOptions": {}
      },
      "id": "c1d2e3f4-a5b6-4c7d-8e9f-0a1b2c3d4e5f",
      "name": "Send Slack DM",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [1640, 300],
      "credentials": {"slackApi": {"id": "slack_api", "name": "slack_api"}}
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
          "conditions": [
            {
              "id": "d2e3f4a5-b6c7-4d8e-9f0a-1b2c3d4e5f6a",
              "leftValue": "={{ $('Build Ticket').item.json._severity }}",
              "rightValue": "Critical",
              "operator": {"type": "string", "operation": "equals"}
            }
          ],
          "combinator": "and"
        }
      },
      "id": "e3f4a5b6-c7d8-4e9f-0a1b-2c3d4e5f6a7b",
      "name": "Check if Critical",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1860, 300]
    },
    {
      "parameters": {
        "operation": "post",
        "channel": "={{ $env.SLACK_CHANNEL_ESCALATIONS }}",
        "text": "=:rotating_light: *CRITICAL ESCALATION*: {{ $('Build Ticket').item.json._ticket_title }} | <{{ $('Build Ticket').item.json.intercom_link }}|View>",
        "otherOptions": {}
      },
      "id": "f4a5b6c7-d8e9-4f0a-1b2c-3d4e5f6a7b8c",
      "name": "Post to Critical Escalations",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [2080, 200],
      "credentials": {"slackApi": {"id": "slack_api", "name": "slack_api"}}
    },
    {
      "parameters": {},
      "id": "a5b6c7d8-e9f0-4a1b-2c3d-4e5f6a7b8c9d",
      "name": "Done",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [2080, 400]
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {"main": [[{"node": "Build Ticket", "type": "main", "index": 0}]]},
    "Build Ticket": {"main": [[{"node": "Lookup Team Leader", "type": "main", "index": 0}]]},
    "Lookup Team Leader": {"main": [[{"node": "Extract Team Leader", "type": "main", "index": 0}]]},
    "Extract Team Leader": {"main": [[{"node": "Check Mapping Found", "type": "main", "index": 0}]]},
    "Check Mapping Found": {
