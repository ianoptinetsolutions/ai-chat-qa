      ]
    },
    "Set Assigned To (Leader)": {"main": [[{"node": "Insert Ticket to Supabase", "type": "main", "index": 0}]]},
    "Set Assigned To (Fallback)": {"main": [[{"node": "Insert Ticket to Supabase", "type": "main", "index": 0}]]},
    "Insert Ticket to Supabase": {"main": [[{"node": "Send Slack DM", "type": "main", "index": 0}]]},
    "Send Slack DM": {"main": [[{"node": "Check if Critical", "type": "main", "index": 0}]]},
