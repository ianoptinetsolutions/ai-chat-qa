      "id": "a1b2c3d4-0001-0001-0001-000000000002",
      "name": "Fetch Conversations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        64,
        304
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "i3XvETOwRH8suX0M",
          "name": "Intercom API"
        }
