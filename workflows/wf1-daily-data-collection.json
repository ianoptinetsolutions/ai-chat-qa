    {
      "parameters": {
        "jsCode": "const pages = $input.all();\n\n// Flatten all paginated pages into individual conversations\nconst allConversations = [];\nfor (const page of pages) {\n  const convos = page.json.conversations || [];\n  for (const convo of convos) {\n    allConversations.push(convo);\n  }\n}\n\n// Keep ALL conversations. Tag each with _is_bot_handled based on statistics.\n// Bot-handled = no human admin replied (first_admin_reply_at is null/undefined)\nreturn allConversations.map(convo => {\n  const stats = convo.statistics;\n  const isBotHandled = !(stats &&\n    stats.first_admin_reply_at !== null &&\n    stats.first_admin_reply_at !== undefined);\n  return { json: { ...convo, _is_bot_handled: isBotHandled } };\n});"
      },
