        "nodeCredentialType": "httpHeaderAuth",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000005",
      "name": "Get Full Conversation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1200,
        288
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "i3XvETOwRH8suX0M",
          "name": "Intercom API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const convo = $input.first().json;\ntry {\n  const conversationId = convo.id;\n  const createdAt = new Date(convo.created_at * 1000).toISOString();\n  const collectedAt = new Date().toISOString();\n  const status = convo.state || 'closed';\n  const intercomLink = `https://app.intercom.com/a/inbox/conversation/${conversationId}`;\n  const contact = convo.contacts?.contacts?.[0];\n  const playerId = contact?.external_id || contact?.id || 'unknown';\n  const tags = (convo.tags?.tags || []).map(t => t.name).join(', ');\n  const isBotHandled = convo._is_bot_handled === true;\n  const lines = [];\n  const firstBody = convo.conversation_message?.body;\n  if (firstBody) {\n    const ts = new Date(convo.created_at * 1000).toISOString();\n    const cleanBody = stripHtml(firstBody);\n    lines.push(`[${ts}] PLAYER: ${cleanBody || '[Image attached]'}`);\n  }\n  let agentName = isBotHandled ? 'Bot' : 'Unknown';\n  const parts = convo.conversation_parts?.conversation_parts || [];\n  for (const part of parts) {\n    const authorType = part.author?.type;\n    let role;\n    if (authorType === 'bot' || authorType === 'operator') {\n      role = 'BOT';\n    } else if (authorType === 'admin' || authorType === 'team') {\n      role = 'AGENT';\n      if (agentName === 'Unknown' && part.author?.name) agentName = part.author.name;\n    } else {\n      role = 'PLAYER';\n    }\n    const ts = new Date(part.created_at * 1000).toISOString();\n    let body = part.body ? stripHtml(part.body) : '';\n    if (!body && part.attachments?.length > 0) {\n      const attachment = part.attachments[0];\n      body = attachment.content_type?.startsWith('image/') ? '[Image attached]' : '[File attached]';\n    }\n    if (body) lines.push(`[${ts}] ${role}: ${body}`);\n  }\n  return [{ json: { conversation_id: conversationId, player_id: playerId, agent_name: agentName, transcript: lines.join('\\n'), tags, created_at: createdAt, collected_at: collectedAt, status, intercom_link: intercomLink, is_bot_handled: isBotHandled } }];\n} catch (err) { throw new Error(`Format failed for ${convo?.id}: ${err.message}`); }\nfunction stripHtml(html) {\n  if (!html) return '';\n  return html\n    .replace(/<br\\s*\\/?>/gi, '\\n')\n    .replace(/<p>/gi, '')\n    .replace(/<\\/p>/gi, '\\n')\n    .replace(/<[^>]+>/g, '')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/&quot;/g, '\"')\n    .replace(/&#39;/g, \"'\")\n    .replace(/&nbsp;/g, ' ')\n    .trim();\n}"
      },
