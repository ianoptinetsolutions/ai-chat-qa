      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        -144,
        304
      ]
    },
    {
      "parameters": {
        "url": "https://api.intercom.io/conversations",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "state",
              "value": "closed"
            },
            {
              "name": "per_page",
              "value": "150"
            },
            {
              "name": "updated_since",
              "value": "={{ Math.floor((Date.now() - 86400000) / 1000) }}"
            }
          ]
        },
        "options": {
          "pagination": {
            "pagination": {
              "paginationMode": "responseContainsNextURL",
              "nextURL": "={{ ($response.body.pages && $response.body.pages.next && $response.body.pages.next.starting_after) ? 'https://api.intercom.io/conversations?state=closed&per_page=150&starting_after=' + $response.body.pages.next.starting_after : '' }}",
              "limitPagesFetched": true,
              "maxRequests": 20
            }
          }
        }
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000002",
      "name": "Fetch Conversations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        64,
        304
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "i3XvETOwRH8suX0M",
          "name": "Intercom API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const pages = $input.all();\n\n// Flatten all paginated pages into individual conversations\nconst allConversations = [];\nfor (const page of pages) {\n  const convos = page.json.conversations || [];\n  for (const convo of convos) {\n    allConversations.push(convo);\n  }\n}\n\n// Keep ALL conversations. Tag each with _is_bot_handled based on statistics.\n// Bot-handled = no human admin replied (first_admin_reply_at is null/undefined)\nreturn allConversations.map(convo => {\n  const stats = convo.statistics;\n  const isBotHandled = !(stats &&\n    stats.first_admin_reply_at !== null &&\n    stats.first_admin_reply_at !== undefined);\n  return { json: { ...convo, _is_bot_handled: isBotHandled } };\n});"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000003",
      "name": "Tag All Conversations",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        288,
        304
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "has-convos-check",
              "leftValue": "={{ $input.all().length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "f1a2b3c4-d5e6-7890-fabc-012345678901",
      "name": "Has Conversations?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        512,
