    {
      "parameters": {
        "jsCode": "const m = $('Compile Metrics').first().json;\n\nconst satEmoji = m.satisfaction_rate >= 80 ? ':white_check_mark:' : m.satisfaction_rate >= 60 ? ':warning:' : ':red_circle:';\n\n// Header + stats\nconst header = `:bar_chart: *Daily Chat QA Report \u2014 ${m.date}*`;\nconst stats = `*Total:* ${m.total_analyzed}  |  ${satEmoji} *Satisfaction:* ${m.satisfaction_rate}%  |  :rotating_light: *Critical:* ${m.critical_count}  |  *High:* ${m.high_count}  |  *Med:* ${m.medium_count}  |  *Low:* ${m.low_count}`;\n\n// Critical & High Priority\nlet critHigh = '*:red_circle: Critical & High Priority*';\nif (m.critical_high_items.length > 0) {\n  critHigh += '\\n' + m.critical_high_items.slice(0, 10).map(i => {\n    const action = i.recommended_action ? (i.recommended_action.length > 120 ? i.recommended_action.substring(0, 120) + '...' : i.recommended_action) : 'N/A';\n    return `>*[${i.severity}]* ${i.agent_name}  |  _${i.issue_category}_\\n>${action}  |  <${i.intercom_link}|View>`;\n  }).join('\\n');\n} else {\n  critHigh += '\\n>_None today_';\n}\n\n// Top Issues\nconst topIssues = '*:clipboard: Top Issues*\\n' + m.top_issues.map((i, idx) => `>${idx + 1}. ${i.category}: *${i.count}*`).join('\\n');\n\n// Agent Flags\nconst agentFlags = '*:triangular_flag_on_post: Agent Flags* _(avg score \u2264 2)_\\n' +\n  (m.agent_flags.length > 0\n    ? m.agent_flags.map(a => `>\u2022 ${a.agent_name}: avg *${a.avg_score}* (${a.conversation_count} convos)`).join('\\n')\n    : '>_None today_');\n\nconst fullText = [header, stats, '', critHigh, '', topIssues, '', agentFlags].join('\\n');\n\nreturn [{ json: { text: fullText } }];\n"
      },
