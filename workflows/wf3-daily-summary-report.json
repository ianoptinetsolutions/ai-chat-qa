    {
      "parameters": {
        "operation": "getAll",
        "tableId": "qa_analysis",
        "returnAll": true
      },
      "id": "b2c3d4e5-f6a7-4b8c-9d0e-1f2a3b4c5d6e",
      "name": "Read Analysis Results",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        320,
        304
      ],
      "credentials": {
        "supabaseApi": {
          "id": "48UlSg2STuVckZm2",
          "name": "Supabase account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const pendingCount = 0;\nconst rows = $input.all().map(item => item.json);\nconst today = new Date().toISOString().split('T')[0];\nconst counts = { Critical: 0, High: 0, Medium: 0, Low: 0 };\nconst categoryMap = {};\nconst criticalHighItems = [];\nconst agentScores = {};\nfor (const row of rows) {\n  const severity = row.severity || 'Low';\n  const category = row.issue_category || 'Other';\n  const agentName = row.agent_name || 'Unknown';\n  const agentScore = parseInt(row.agent_score || 3, 10);\n  const convId = row.conversation_id;\n  const summary = row.summary || '';\n  const recommendedAction = row.recommended_action || '';\n  const intercomLink = row.intercom_link || '';\n  if (counts.hasOwnProperty(severity)) counts[severity]++;\n  categoryMap[category] = (categoryMap[category] || 0) + 1;\n  if (severity === 'Critical' || severity === 'High') criticalHighItems.push({ conversation_id: convId, agent_name: agentName, issue_category: category, severity, summary, recommended_action: recommendedAction, intercom_link: intercomLink });\n  if (!agentScores[agentName]) agentScores[agentName] = { total: 0, count: 0 };\n  agentScores[agentName].total += agentScore;\n  agentScores[agentName].count++;\n}\nconst total = rows.length;\nconst satisfactionRate = total > 0 ? Math.round((counts.Low / total) * 1000) / 10 : 0;\nconst topIssues = Object.entries(categoryMap).sort((a, b) => b[1] - a[1]).slice(0, 5).map(([category, count]) => ({ category, count }));\nconst agentFlags = Object.entries(agentScores).map(([name, data]) => ({ agent_name: name, avg_score: Math.round((data.total / data.count) * 10) / 10, conversation_count: data.count })).filter(a => a.avg_score <= 2).sort((a, b) => a.avg_score - b.avg_score);\nreturn [{ json: { date: today, total_analyzed: total, pending_analysis_count: pendingCount, critical_count: counts.Critical, high_count: counts.High, medium_count: counts.Medium, low_count: counts.Low, satisfaction_rate: satisfactionRate, top_issues: topIssues, critical_high_items: criticalHighItems, agent_flags: agentFlags, generated_at: new Date().toISOString() } }];\n"
      },
      "id": "c3d4e5f6-a7b8-4c9d-0e1f-2a3b4c5d6e7f",
      "name": "Compile Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        544,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const m = $input.first().json;\nconst satColor = m.satisfaction_rate >= 80 ? '#10b981' : m.satisfaction_rate >= 60 ? '#f59e0b' : '#ef4444';\nconst satBg = m.satisfaction_rate >= 80 ? '#d1fae5' : m.satisfaction_rate >= 60 ? '#fef3c7' : '#fee2e2';\n\nconst sevBadge = (sev) => {\n  const colors = { Critical: ['#dc2626','#fee2e2'], High: ['#ea580c','#ffedd5'], Medium: ['#d97706','#fef3c7'], Low: ['#16a34a','#dcfce7'] };\n  const [fg, bg] = colors[sev] || ['#6b7280','#f3f4f6'];\n  return `<span style=\"background:${bg};color:${fg};font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;white-space:nowrap\">${sev}</span>`;\n};\n\nconst critHighRows = m.critical_high_items.length > 0\n  ? m.critical_high_items.slice(0, 20).map((i, idx) => `<tr style=\"background:${idx%2===0?'#ffffff':'#fafafa'};border-bottom:1px solid #f1f5f9\"><td style=\"padding:10px 12px;font-size:11px;color:#94a3b8;font-family:monospace\">${i.conversation_id}</td><td style=\"padding:10px 12px;font-size:12px;font-weight:600;color:#1e293b\">${i.agent_name}</td><td style=\"padding:10px 12px\"><span style=\"background:#eff6ff;color:#3b82f6;font-size:11px;padding:2px 8px;border-radius:4px\">${i.issue_category}</span></td><td style=\"padding:10px 12px\">${sevBadge(i.severity)}</td><td style=\"padding:10px 12px;font-size:11px;color:#475569;line-height:1.5\">${i.recommended_action}</td><td style=\"padding:10px 12px;text-align:center\"><a href=\"${i.intercom_link}\" style=\"background:#1e293b;color:#fff;font-size:11px;padding:4px 12px;border-radius:4px;text-decoration:none;white-space:nowrap\">&#8599; View</a></td></tr>`).join('')\n  : '<tr><td colspan=\"6\" style=\"padding:20px;text-align:center;color:#94a3b8;font-style:italic;font-size:13px\">No critical or high priority conversations today</td></tr>';\n\nconst topRows = m.top_issues.map((i, idx) => {\n  const pct = m.total_analyzed > 0 ? Math.round((i.count / m.total_analyzed) * 100) : 0;\n  return `<tr style=\"border-bottom:1px solid #f1f5f9\"><td style=\"padding:10px 12px;font-size:13px;font-weight:700;color:#94a3b8\">#${idx+1}</td><td style=\"padding:10px 12px;font-size:12px;color:#1e293b\">${i.category}</td><td style=\"padding:10px 12px\"><div style=\"background:#f1f5f9;border-radius:4px;overflow:hidden;height:8px;width:80px;display:inline-block;vertical-align:middle\"><div style=\"background:#3b82f6;height:8px;width:${pct}%\"></div></div></td><td style=\"padding:10px 12px;text-align:right;font-size:13px;font-weight:700;color:#1e293b\">${i.count}</td></tr>`;\n}).join('');\n\nconst flagRows = m.agent_flags.length > 0\n  ? m.agent_flags.map(a => `<tr style=\"border-bottom:1px solid #fecaca\"><td style=\"padding:10px 12px;font-size:12px;font-weight:600;color:#1e293b\">${a.agent_name}</td><td style=\"padding:10px 12px;text-align:center\"><span style=\"background:#fee2e2;color:#dc2626;font-size:14px;font-weight:700;padding:4px 12px;border-radius:6px\">${a.avg_score}</span></td><td style=\"padding:10px 12px;text-align:center;font-size:12px;color:#64748b\">${a.conversation_count} convos</td></tr>`).join('')\n  : '<tr><td colspan=\"3\" style=\"padding:16px;text-align:center;color:#94a3b8;font-style:italic;font-size:12px\">No flags today &#10003;</td></tr>';\n\nconst pendingBanner = m.pending_analysis_count > 0\n  ? `<div style=\"background:#fef3c7;border-left:4px solid #f59e0b;padding:12px 32px;font-size:12px;color:#92400e\">&#9888; <strong>${m.pending_analysis_count} conversations still pending analysis</strong> \u2014 this report may be incomplete.</div>`\n  : '';\n\nconst html = `<!DOCTYPE html><html><head><meta charset=\"UTF-8\"></head><body style=\"margin:0;padding:0;background:#e2e8f0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#e2e8f0;padding:24px 0\"><tr><td align=\"center\">\n<table width=\"1200\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:1200px;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.12)\">\n\n${pendingBanner ? `<tr><td colspan=\"2\">${pendingBanner}</td></tr>` : ''}\n\n<!-- HEADER -->\n<tr><td colspan=\"2\" style=\"background:linear-gradient(135deg,#0f172a 0%,#1e293b 60%,#0f4c75 100%);padding:32px 40px\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr valign=\"middle\">\n    <td><p style=\"margin:0 0 4px;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:0.1em\">Chat QA System</p><h1 style=\"margin:0;color:#f8fafc;font-size:24px;font-weight:700;letter-spacing:-0.02em\">Daily QA Report</h1><p style=\"margin:6px 0 0;color:#94a3b8;font-size:14px\">${m.date} &nbsp;&#183;&nbsp; Generated ${new Date(m.generated_at).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})}</p></td>\n    <td style=\"text-align:right\">\n      <table cellpadding=\"0\" cellspacing=\"0\" style=\"display:inline-table\"><tr>\n        <td style=\"padding:0 6px\"><div style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:14px 20px;text-align:center;min-width:70px\"><div style=\"font-size:30px;font-weight:800;color:#f8fafc;line-height:1\">${m.total_analyzed}</div><div style=\"font-size:10px;color:#64748b;margin-top:4px;text-transform:uppercase;letter-spacing:0.05em\">Total</div></div></td>\n        <td style=\"padding:0 6px\"><div style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:14px 20px;text-align:center;min-width:70px\"><div style=\"font-size:30px;font-weight:800;color:${satColor};line-height:1\">${m.satisfaction_rate}%</div><div style=\"font-size:10px;color:#64748b;margin-top:4px;text-transform:uppercase;letter-spacing:0.05em\">Satisfaction</div></div></td>\n        <td style=\"padding:0 6px\"><div style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:14px 20px;text-align:center;min-width:70px\"><div style=\"font-size:30px;font-weight:800;color:#ef4444;line-height:1\">${m.critical_count}</div><div style=\"font-size:10px;color:#64748b;margin-top:4px;text-transform:uppercase;letter-spacing:0.05em\">Critical</div></div></td>\n        <td style=\"padding:0 6px\"><div style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:14px 20px;text-align:center;min-width:70px\"><div style=\"font-size:30px;font-weight:800;color:#f97316;line-height:1\">${m.high_count}</div><div style=\"font-size:10px;color:#64748b;margin-top:4px;text-transform:uppercase;letter-spacing:0.05em\">High</div></div></td>\n        <td style=\"padding:0 6px\"><div style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:14px 20px;text-align:center;min-width:70px\"><div style=\"font-size:30px;font-weight:800;color:#fbbf24;line-height:1\">${m.medium_count}</div><div style=\"font-size:10px;color:#64748b;margin-top:4px;text-transform:uppercase;letter-spacing:0.05em\">Medium</div></div></td>\n        <td style=\"padding:0 6px\"><div style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:14px 20px;text-align:center;min-width:70px\"><div style=\"font-size:30px;font-weight:800;color:#34d399;line-height:1\">${m.low_count}</div><div style=\"font-size:10px;color:#64748b;margin-top:4px;text-transform:uppercase;letter-spacing:0.05em\">Low</div></div></td>\n      </tr></table>\n    </td>\n  </tr></table>\n</td></tr>\n\n<!-- BODY -->\n<tr>\n  <!-- LEFT: Critical & High -->\n  <td width=\"65%\" valign=\"top\" style=\"background:#ffffff;padding:28px 32px;border-right:1px solid #f1f5f9\">\n    <p style=\"margin:0 0 16px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.08em\">&#9888; Critical &amp; High Priority</p>\n    <table width=\"100%\" style=\"border-collapse:collapse\">\n      <thead><tr style=\"background:#f8fafc;border-bottom:2px solid #e2e8f0\">\n        <th style=\"padding:10px 12px;text-align:left;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.05em\">Conv ID</th>\n        <th style=\"padding:10px 12px;text-align:left;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.05em\">Agent</th>\n        <th style=\"padding:10px 12px;text-align:left;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.05em\">Category</th>\n        <th style=\"padding:10px 12px;text-align:left;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.05em\">Severity</th>\n        <th style=\"padding:10px 12px;text-align:left;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.05em\">Recommended Action</th>\n        <th style=\"padding:10px 12px;text-align:center;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.05em\">Link</th>\n      </tr></thead>\n      <tbody>${critHighRows}</tbody>\n    </table>\n  </td>\n  <!-- RIGHT: Top Issues + Agent Flags -->\n  <td width=\"35%\" valign=\"top\" style=\"background:#ffffff;padding:28px 32px\">\n    <p style=\"margin:0 0 16px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.08em\">&#128202; Top Issues by Category</p>\n    <table width=\"100%\" style=\"border-collapse:collapse;margin-bottom:28px\">\n      <thead><tr style=\"background:#f8fafc;border-bottom:2px solid #e2e8f0\">\n        <th style=\"padding:10px 12px;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase\">#</th>\n        <th style=\"padding:10px 12px;text-align:left;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase\">Category</th>\n        <th style=\"padding:10px 12px;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase\">Trend</th>\n        <th style=\"padding:10px 12px;text-align:right;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase\">Count</th>\n      </tr></thead>\n      <tbody>${topRows}</tbody>\n    </table>\n    <p style=\"margin:0 0 16px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.08em\">&#9873; Agent Flags <span style=\"font-size:9px;font-weight:400;color:#cbd5e1\">(avg score &le; 2)</span></p>\n    <table width=\"100%\" style=\"border-collapse:collapse;background:#fff5f5;border-radius:8px;overflow:hidden\">\n      <thead><tr style=\"background:#fef2f2;border-bottom:2px solid #fecaca\">\n        <th style=\"padding:10px 12px;text-align:left;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase\">Agent</th>\n        <th style=\"padding:10px 12px;text-align:center;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase\">Avg Score</th>\n        <th style=\"padding:10px 12px;text-align:center;font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase\">Volume</th>\n      </tr></thead>\n      <tbody>${flagRows}</tbody>\n    </table>\n  </td>\n</tr>\n\n<!-- FOOTER -->\n<tr><td colspan=\"2\" style=\"background:#f8fafc;padding:16px 40px;border-top:1px solid #e2e8f0\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n    <td style=\"font-size:11px;color:#94a3b8\">&#128187; Chat QA System &nbsp;&#183;&nbsp; AI-generated report</td>\n    <td style=\"text-align:right;font-size:11px;color:#cbd5e1\">${m.generated_at}</td>\n  </tr></table>\n</td></tr>\n\n</table>\n</td></tr></table>\n</body></html>`;\n\nconst subject = `[QA Report] ${m.date} \u2014 ${m.total_analyzed} convos | ${m.satisfaction_rate}% satisfaction${m.critical_count > 0 ? ` | ${m.critical_count} CRITICAL` : ''}`;\nreturn [{ json: { subject, html_body: html, plain_text: `Daily QA Report ${m.date}: ${m.total_analyzed} conversations, ${m.satisfaction_rate}% satisfaction, ${m.critical_count} critical, ${m.high_count} high`, metrics: m } }];\n"
      },
