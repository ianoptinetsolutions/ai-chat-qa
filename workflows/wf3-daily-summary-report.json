      "parameters": {
        "jsCode": "// Read Pending Count returns 0 items when all conversations are analyzed.\n// This node always outputs exactly 1 item so the chain never stops.\nconst items = $input.all();\nconst pendingCount = items.filter(i => i.json && i.json.conversation_id).length;\nreturn [{ json: { pending_count: pendingCount } }];"
